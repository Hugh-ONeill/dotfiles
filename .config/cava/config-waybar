# Cava config for waybar

[general]
bars = 8
framerate = 30
sensitivity = 100
autosens = 1

[input]
method = pipewire
source = auto

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7

[color]
gradient = 1
gradient_count = 2
gradient_color_1 = '#b4befe'
gradient_color_2 = '#cba6f7'

[smoothing]
noise_reduction = 77
