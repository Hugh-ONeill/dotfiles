#!/bin/bash

# Read JSON input from stdin
input=$(cat)

# Function to abbreviate large numbers (e.g., 150000 -> 150k)
abbreviate_num() {
  local num=$1
  if [ "$num" -ge 1000000 ]; then
    printf "%.1fm" "$(echo "$num / 1000000" | bc -l)"
  elif [ "$num" -ge 1000 ]; then
    printf "%.1fk" "$(echo "$num / 1000" | bc -l)"
  else
    echo "$num"
  fi
}

# Extract all JSON values in one jq call for performance
eval "$(echo "$input" | jq -r '
  @sh "dir=\(.workspace.current_dir // "")",
  @sh "cwd=\(.workspace.current_dir // "")",
  @sh "model_name=\(.model.display_name // "Unknown")",
  @sh "context_size=\(.context_window.context_window_size // 200000)",
  @sh "input_tokens=\((.context_window.current_usage.input_tokens // 0) + (.context_window.current_usage.cache_creation_input_tokens // 0) + (.context_window.current_usage.cache_read_input_tokens // 0))",
  @sh "output_tokens=\(.context_window.current_usage.output_tokens // 0)",
  @sh "lines_added=\(.cost.total_lines_added // 0)",
  @sh "lines_removed=\(.cost.total_lines_removed // 0)",
  @sh "output_style=\(.output_style.name // "default")",
  @sh "total_cost=\(.cost.total_cost_usd // 0)",
  @sh "duration_ms=\(.cost.total_duration_ms // 0)"
')"

# Get split directory parts
dir_first=$(~/.local/bin/directory-split first "$dir")
dir_second=$(~/.local/bin/directory-split second "$dir")


# Get git info if in a git repo
git_branch=''
git_dirty=''
git_ahead=0
git_behind=0
if git -C "$cwd" rev-parse --git-dir &>/dev/null 2>&1; then
  git_branch=$(git -C "$cwd" branch --show-current 2>/dev/null || echo 'HEAD')
  # Check for uncommitted changes
  if ! git -C "$cwd" diff --quiet 2>/dev/null || ! git -C "$cwd" diff --cached --quiet 2>/dev/null; then
    git_dirty='*'
  fi
  # Get ahead/behind counts
  git_status=$(git -C "$cwd" rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)
  if [ -n "$git_status" ]; then
    git_ahead=$(echo "$git_status" | cut -f1)
    git_behind=$(echo "$git_status" | cut -f2)
  fi
fi

# Format cost
total_cost=$(printf "%.2f" $total_cost)

# Calculate context usage percentage
if [ "$context_size" -gt 0 ]; then
  context_percent=$(awk "BEGIN {printf \"%.0f\", ($input_tokens / $context_size) * 100}")
else
  context_percent=0
fi

# Format duration (convert ms to days/hours/minutes)
duration_total_min=$((duration_ms / 60000))
duration_days=$((duration_total_min / 1440))
duration_hours=$(( (duration_total_min % 1440) / 60 ))
duration_min=$((duration_total_min % 60))
duration=""
[ "$duration_days" -gt 0 ] && duration+="${duration_days}d"
[ "$duration_hours" -gt 0 ] && duration+="${duration_hours}h"
duration+="${duration_min}m"

# ${THEME_NAME} colors
# Structural colors
fg_text=$'\033[38;2;${TEXT_RGB}m'
fg_mantle=$'\033[38;2;${MANTLE_RGB}m'
fg_base=$'\033[38;2;${BASE_RGB}m'
fg_surface0=$'\033[38;2;${SURFACE0_RGB}m'
fg_subtext0=$'\033[38;2;${SUBTEXT0_RGB}m'
bg_surface0=$'\033[48;2;${SURFACE0_RGB}m'
bg_subtext0=$'\033[48;2;${SUBTEXT0_RGB}m'
bg_text=$'\033[48;2;${TEXT_RGB}m'
bg_base=$'\033[48;2;${BASE_RGB}m'
bg_crust=$'\033[48;2;${CRUST_RGB}m'
fg_crust=$'\033[38;2;${CRUST_RGB}m'

# Auto-contrasting foreground for each gradient color (based on luminance)
fg_g0_text=$'\033[38;2;${GRADIENT_FG_0_RGB}m'
fg_g1_text=$'\033[38;2;${GRADIENT_FG_1_RGB}m'
fg_g2_text=$'\033[38;2;${GRADIENT_FG_2_RGB}m'
fg_g3_text=$'\033[38;2;${GRADIENT_FG_3_RGB}m'
fg_g4_text=$'\033[38;2;${GRADIENT_FG_4_RGB}m'
fg_g5_text=$'\033[38;2;${GRADIENT_FG_5_RGB}m'
fg_g6_text=$'\033[38;2;${GRADIENT_FG_6_RGB}m'
fg_g7_text=$'\033[38;2;${GRADIENT_FG_7_RGB}m'
fg_g8_text=$'\033[38;2;${GRADIENT_FG_8_RGB}m'
fg_g9_text=$'\033[38;2;${GRADIENT_FG_9_RGB}m'

# Gradient colors (fg for separators, bg for sections)
fg_g0=$'\033[38;2;${GRADIENT_0_RGB}m'
fg_g1=$'\033[38;2;${GRADIENT_1_RGB}m'
fg_g2=$'\033[38;2;${GRADIENT_2_RGB}m'
fg_g3=$'\033[38;2;${GRADIENT_3_RGB}m'
fg_g4=$'\033[38;2;${GRADIENT_4_RGB}m'
fg_g5=$'\033[38;2;${GRADIENT_5_RGB}m'
fg_g6=$'\033[38;2;${GRADIENT_6_RGB}m'
fg_g7=$'\033[38;2;${GRADIENT_7_RGB}m'
fg_g8=$'\033[38;2;${GRADIENT_8_RGB}m'
fg_g9=$'\033[38;2;${GRADIENT_9_RGB}m'

bg_g0=$'\033[48;2;${GRADIENT_0_RGB}m'
bg_g1=$'\033[48;2;${GRADIENT_1_RGB}m'
bg_g2=$'\033[48;2;${GRADIENT_2_RGB}m'
bg_g3=$'\033[48;2;${GRADIENT_3_RGB}m'
bg_g4=$'\033[48;2;${GRADIENT_4_RGB}m'
bg_g5=$'\033[48;2;${GRADIENT_5_RGB}m'
bg_g6=$'\033[48;2;${GRADIENT_6_RGB}m'
bg_g7=$'\033[48;2;${GRADIENT_7_RGB}m'
bg_g8=$'\033[48;2;${GRADIENT_8_RGB}m'
bg_g9=$'\033[48;2;${GRADIENT_9_RGB}m'

reset=$'\033[0m'

# Powerline separators based on bar style: ${STYLE_BAR}
case "${STYLE_BAR}" in
  angular)
    sep_left=$'\ue0b2'   # U+E0B2 left-facing arrow
    sep_right=$'\ue0b0'  # U+E0B0 right-facing arrow
    sep_mod=$'\ue0b0'    # same for module separators
    ;;
  flame)
    sep_left=$'\ue0b6'   # U+E0B6 left-facing semicircle (start cap)
    sep_right=$'\ue0b4'  # U+E0B4 right-facing semicircle (end cap)
    sep_mod=$'\ue0c0'    # U+E0C0 left-facing flame thick (between modules)
    ;;
  pixels)
    sep_left=$'\ue0b6'   # U+E0B6 left-facing semicircle (start cap)
    sep_right=$'\ue0b4'  # U+E0B4 right-facing semicircle (end cap)
    sep_mod=$'\ue0c6'    # U+E0C6 pixelated squares big (between modules)
    ;;
  waveform)
    sep_left=$'\ue0b6'   # U+E0B6 left-facing semicircle (start cap)
    sep_right=$'\ue0b4'  # U+E0B4 right-facing semicircle (end cap)
    sep_mod=$'\ue0c8'    # U+E0C8 waveform (between modules)
    ;;
  slashes)
    sep_left=$'\ue0b8'   # U+E0B8 lower left triangle (start cap, reversed)
    sep_right=$'\ue0be'  # U+E0BE upper right triangle (end cap, reversed)
    sep_mod=$'\ue0be'    # U+E0BE upper right triangle (between modules)
    sep_reversed=true
    ;;
  boxy)
    sep_left='['         # simple bracket (start cap)
    sep_right=']'        # simple bracket (end cap)
    sep_mod='|'          # pipe (between modules)
    ;;
  *)  # rounded (default)
    sep_left=$'\ue0b6'   # U+E0B6 left-facing semicircle
    sep_right=$'\ue0b4'  # U+E0B4 right-facing semicircle
    sep_mod=$'\ue0b4'    # same for module separators
    ;;
esac

# Precompute separator transition colors
# Normal: separator fg = prev section color, bg = next section color
# Reversed (\ slashes): swap fg↔bg since glyph fills opposite side
if [[ "${sep_reversed:-}" == "true" ]]; then
    sep_start="${fg_base}${bg_surface0}"
    sep_s0_g0="${bg_surface0}${fg_g0}"
    sep_g0_g1="${bg_g0}${fg_g1}"
    sep_g1_g2="${bg_g1}${fg_g2}"
    sep_g2_g3="${bg_g2}${fg_g3}"
    sep_g3_g4="${bg_g3}${fg_g4}"
    sep_g4_g5="${bg_g4}${fg_g5}"
    sep_g5_g6="${bg_g5}${fg_g6}"
    sep_g6_g7="${bg_g6}${fg_g7}"
    sep_g7_g8="${bg_g7}${fg_g8}"
    sep_g8_g9="${bg_g8}${fg_g9}"
    sep_g9_text="${bg_g9}${fg_text}"
    sep_end="${bg_text}${fg_base}"
else
    sep_start="${fg_surface0}${bg_base}"
    sep_s0_g0="${fg_surface0}${bg_g0}"
    sep_g0_g1="${fg_g0}${bg_g1}"
    sep_g1_g2="${fg_g1}${bg_g2}"
    sep_g2_g3="${fg_g2}${bg_g3}"
    sep_g3_g4="${fg_g3}${bg_g4}"
    sep_g4_g5="${fg_g4}${bg_g5}"
    sep_g5_g6="${fg_g5}${bg_g6}"
    sep_g6_g7="${fg_g6}${bg_g7}"
    sep_g7_g8="${fg_g7}${bg_g8}"
    sep_g8_g9="${fg_g8}${bg_g9}"
    sep_g9_text="${fg_g9}${bg_text}"
    sep_end="${fg_text}${bg_base}"
fi

# Build statusline
# Start cap: surface0 section (Arch icon)
echo -ne "${sep_start}${sep_left}${reset}"
echo -ne "${fg_text}${bg_surface0}\U000f011b${reset}"

# Section 1 (first part of path) - gradient[0]
echo -ne "${sep_s0_g0}${sep_right}${reset}"
echo -ne "${fg_g0_text}${bg_g0}${dir_first} ${reset}"
echo -ne "${sep_g0_g1}${sep_mod}${reset}"

# Section 2 (second part of path) - gradient[1]
echo -ne "${fg_g1_text}${bg_g1} ${dir_second} ${reset}"
echo -ne "${sep_g1_g2}${sep_mod}${reset}"

# Section 3: Git branch - gradient[2]
if [ -n "$git_branch" ]; then
  git_info="${git_branch}${git_dirty}"
  [ "$git_ahead" -gt 0 ] && git_info+=" ↑${git_ahead}"
  [ "$git_behind" -gt 0 ] && git_info+=" ↓${git_behind}"
  echo -ne "${fg_g2_text}${bg_g2} \U0000f126 ${git_info} ${reset}"
else
  echo -ne "${fg_g2_text}${bg_g2} \U0000f126 — ${reset}"
fi
echo -ne "${sep_g2_g3}${sep_mod}${reset}"

# Section 4: Model name - gradient[3]
echo -ne "${fg_g3_text}${bg_g3} \U0000ee9c [${model_name}] ${reset}"
echo -ne "${sep_g3_g4}${sep_mod}${reset}"

# Section 5: Output style - gradient[4]
echo -ne "${fg_g4_text}${bg_g4} \U0000f075 ${output_style} ${reset}"
echo -ne "${sep_g4_g5}${sep_mod}${reset}"

# Section 6: Tokens in/out - gradient[5]
echo -ne "${fg_g5_text}${bg_g5} \U0000f063 $(abbreviate_num $input_tokens) \U0000f062 $(abbreviate_num $output_tokens) ${reset}"
echo -ne "${sep_g5_g6}${sep_mod}${reset}"

# Section 7: Context percentage - gradient[6]
echo -ne "${fg_g6_text}${bg_g6} \U0000f200 ${context_percent}% ${reset}"
echo -ne "${sep_g6_g7}${sep_mod}${reset}"

# Section 8: Lines changed - gradient[7]
echo -ne "${fg_g7_text}${bg_g7} \U0000f040 +${lines_added} -${lines_removed} ${reset}"
echo -ne "${sep_g7_g8}${sep_mod}${reset}"

# Section 9: Cost - gradient[8]
echo -ne "${fg_g8_text}${bg_g8} \U0000f155 ${total_cost} ${reset}"
echo -ne "${sep_g8_g9}${sep_mod}${reset}"

# Section 10: Duration - gradient[9]
echo -ne "${fg_g9_text}${bg_g9} \U0000f017 ${duration} ${reset}"

# Final cap
echo -ne "${sep_g9_text}${sep_mod}${reset}"
echo -ne "${bg_text} ${sep_end}${sep_right}${reset}"
