#!/bin/bash

# Win98 Angular Statusline for Claude Code

# Read JSON input from stdin
input=$(cat)

# Function to abbreviate large numbers (e.g., 150000 -> 150k)
abbreviate_num() {
  local num=$1
  if [ "$num" -ge 1000000 ]; then
    printf "%.1fm" "$(echo "$num / 1000000" | bc -l)"
  elif [ "$num" -ge 1000 ]; then
    printf "%.1fk" "$(echo "$num / 1000" | bc -l)"
  else
    echo "$num"
  fi
}

# Extract all JSON values in one jq call for performance
eval "$(echo "$input" | jq -r '
  @sh "dir=\(.workspace.current_dir // "")",
  @sh "cwd=\(.workspace.current_dir // "")",
  @sh "model_name=\(.model.display_name // "Unknown")",
  @sh "context_size=\(.context_window.context_window_size // 200000)",
  @sh "input_tokens=\((.context_window.current_usage.input_tokens // 0) + (.context_window.current_usage.cache_creation_input_tokens // 0) + (.context_window.current_usage.cache_read_input_tokens // 0))",
  @sh "output_tokens=\(.context_window.current_usage.output_tokens // 0)",
  @sh "lines_added=\(.cost.total_lines_added // 0)",
  @sh "lines_removed=\(.cost.total_lines_removed // 0)",
  @sh "output_style=\(.output_style.name // "default")",
  @sh "total_cost=\(.cost.total_cost_usd // 0)",
  @sh "duration_ms=\(.cost.total_duration_ms // 0)"
')"

# Get split directory parts
dir_first=$(~/.local/bin/directory-split first "$dir")
dir_second=$(~/.local/bin/directory-split second "$dir")


# Get git info if in a git repo
git_branch=''
git_dirty=''
git_ahead=0
git_behind=0
if git -C "$cwd" rev-parse --git-dir &>/dev/null 2>&1; then
  git_branch=$(git -C "$cwd" branch --show-current 2>/dev/null || echo 'HEAD')
  # Check for uncommitted changes
  if ! git -C "$cwd" diff --quiet 2>/dev/null || ! git -C "$cwd" diff --cached --quiet 2>/dev/null; then
    git_dirty='*'
  fi
  # Get ahead/behind counts
  git_status=$(git -C "$cwd" rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)
  if [ -n "$git_status" ]; then
    git_ahead=$(echo "$git_status" | cut -f1)
    git_behind=$(echo "$git_status" | cut -f2)
  fi
fi

# Format cost
total_cost=$(printf "%.2f" $total_cost)

# Calculate context usage percentage
if [ "$context_size" -gt 0 ]; then
  context_percent=$(awk "BEGIN {printf \"%.0f\", ($input_tokens / $context_size) * 100}")
else
  context_percent=0
fi

# Format duration (convert ms to minutes:seconds)
duration_sec=$((duration_ms / 1000))
duration_min=$((duration_sec / 60))
duration_sec=$((duration_sec % 60))
duration=$(printf "%dm%02ds" $duration_min $duration_sec)

# Win98 pastel colors
fg_text=$'\033[38;2;${TEXT_RGB}m'
fg_mantle=$'\033[38;2;${MANTLE_RGB}m'
fg_base=$'\033[38;2;${BASE_RGB}m'
fg_surface0=$'\033[38;2;${SURFACE0_RGB}m'
fg_subtext0=$'\033[38;2;${SUBTEXT0_RGB}m'
bg_surface0=$'\033[48;2;${SURFACE0_RGB}m'
bg_subtext0=$'\033[48;2;${SUBTEXT0_RGB}m'
bg_text=$'\033[48;2;${TEXT_RGB}m'

# Gradient colors (fg for separators, bg for sections)
fg_g0=$'\033[38;2;${GRADIENT_0_RGB}m'
fg_g1=$'\033[38;2;${GRADIENT_1_RGB}m'
fg_g2=$'\033[38;2;${GRADIENT_2_RGB}m'
fg_g3=$'\033[38;2;${GRADIENT_3_RGB}m'
fg_g4=$'\033[38;2;${GRADIENT_4_RGB}m'
fg_g5=$'\033[38;2;${GRADIENT_5_RGB}m'
fg_g6=$'\033[38;2;${GRADIENT_6_RGB}m'
fg_g7=$'\033[38;2;${GRADIENT_7_RGB}m'
fg_g8=$'\033[38;2;${GRADIENT_8_RGB}m'
fg_g9=$'\033[38;2;${GRADIENT_9_RGB}m'

bg_g0=$'\033[48;2;${GRADIENT_0_RGB}m'
bg_g1=$'\033[48;2;${GRADIENT_1_RGB}m'
bg_g2=$'\033[48;2;${GRADIENT_2_RGB}m'
bg_g3=$'\033[48;2;${GRADIENT_3_RGB}m'
bg_g4=$'\033[48;2;${GRADIENT_4_RGB}m'
bg_g5=$'\033[48;2;${GRADIENT_5_RGB}m'
bg_g6=$'\033[48;2;${GRADIENT_6_RGB}m'
bg_g7=$'\033[48;2;${GRADIENT_7_RGB}m'
bg_g8=$'\033[48;2;${GRADIENT_8_RGB}m'
bg_g9=$'\033[48;2;${GRADIENT_9_RGB}m'

reset=$'\033[0m'

# Powerline separators (angular)
sep_left=$'\ue0b2'  # U+E0B2 left-facing triangle (used at the start)
sep_right=$'\ue0b0' # U+E0B0 right-facing triangle (used between sections)

# Build statusline with spread out values
# Start with surface0 section (Arch icon) - icon uses subtext0 color
echo -ne "${fg_surface0}${sep_left}${reset}"
echo -ne "${fg_text}${bg_surface0}\U000f011b${reset}"

# Section 1 (first part of path) - gradient[0]
echo -ne "${fg_surface0}${bg_g0}${sep_right}${reset}"
echo -ne "${fg_text}${bg_g0}${dir_first} ${reset}"
echo -ne "${fg_g0}${bg_g1}${sep_right}${reset}"

# Section 2 (second part of path) - gradient[1]
echo -ne "${fg_text}${bg_g1}${dir_second} ${reset}"
echo -ne "${fg_g1}${bg_g2}${sep_right}${reset}"

# Section 3: Git branch - gradient[2]
if [ -n "$git_branch" ]; then
  git_info="${git_branch}${git_dirty}"
  [ "$git_ahead" -gt 0 ] && git_info+=" ↑${git_ahead}"
  [ "$git_behind" -gt 0 ] && git_info+=" ↓${git_behind}"
  echo -ne "${fg_text}${bg_g2} \U0000f126 ${git_info} ${reset}"
else
  echo -ne "${fg_text}${bg_g2} \U0000f126 — ${reset}"
fi
echo -ne "${fg_g2}${bg_g3}${sep_right}${reset}"

# Section 4: Model name - gradient[3]
echo -ne "${fg_text}${bg_g3} \U0000ee9c [${model_name}] ${reset}"
echo -ne "${fg_g3}${bg_g4}${sep_right}${reset}"

# Section 5: Output style - gradient[4]
echo -ne "${fg_text}${bg_g4} \U0000f075 ${output_style} ${reset}"
echo -ne "${fg_g4}${bg_g5}${sep_right}${reset}"

# Section 6: Tokens in/out - gradient[5]
echo -ne "${fg_text}${bg_g5} \U0000f063 $(abbreviate_num $input_tokens) \U0000f062 $(abbreviate_num $output_tokens) ${reset}"
echo -ne "${fg_g5}${bg_g6}${sep_right}${reset}"

# Section 7: Context percentage - gradient[6]
echo -ne "${fg_text}${bg_g6} \U0000f200 ${context_percent}% ${reset}"
echo -ne "${fg_g6}${bg_g7}${sep_right}${reset}"

# Section 8: Lines changed - gradient[7]
echo -ne "${fg_text}${bg_g7} \U0000f040 +${lines_added} -${lines_removed} ${reset}"
echo -ne "${fg_g7}${bg_g8}${sep_right}${reset}"

# Section 9: Cost - gradient[8]
echo -ne "${fg_text}${bg_g8} \U0000f155 ${total_cost} ${reset}"
echo -ne "${fg_g8}${bg_g9}${sep_right}${reset}"

# Section 10: Duration - gradient[9]
echo -ne "${fg_text}${bg_g9} \U0000f017 ${duration} ${reset}"
echo -ne "${fg_g9}${bg_text}${sep_right}${reset}"

# Final cap
echo -ne "${fg_text}${sep_right}${reset}"
