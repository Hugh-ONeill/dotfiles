/* vim:ft=css */
/* Chromatic Aberration — clean accent borders */

/* ---- Window ---- */

window {
    border:        2px;
    border-color:  @accent;
}

/* ---- Selected Element ---- */

element selected.normal {
    text-color:       @base;
    background-color: @accent;
}

element-text selected {
    text-color: @base;
}

element-icon selected {
    text-color: @base;
}

/* ---- Input Bar ---- */

entry {
    border:        1px;
    border-color:  @accent;
}
