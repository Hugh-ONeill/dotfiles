# ${THEME_NAME} theme for hyprtoolkit

# Colors
background = rgb(${BASE_NOHASH})
base = rgb(${SURFACE0_NOHASH})
alternate_base = rgb(${SURFACE1_NOHASH})
text = rgb(${TEXT_NOHASH})
bright_text = rgb(${SUBTEXT1_NOHASH})
accent = rgb(${ACCENT_NOHASH})
accent_secondary = rgb(${ACCENT_SECONDARY_NOHASH})

# Typography
font_family = ${FONT_FAMILY}
font_family_monospace = ${FONT_FAMILY} Mono
font_size = ${FONT_SIZE}
h1_size = 18
h2_size = 14
h3_size = 12
small_font_size = 10

# Rounding
rounding_large = 6
rounding_small = ${STYLE_CORNER_RADIUS}

# Icons
icon_theme = Papirus-Dark
