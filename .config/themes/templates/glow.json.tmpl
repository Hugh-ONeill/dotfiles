{
  "document": {
    "block_prefix": "",
    "block_suffix": "",
    "color": "${TEXT}",
    "margin": 2
  },
  "block_quote": {
    "color": "${SUBTEXT0}",
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "",
    "color": "${ACCENT}",
    "bold": true
  },
  "h1": {
    "prefix": "# ",
    "color": "${GRADIENT_0}",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "${GRADIENT_2}",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "${GRADIENT_4}",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "${GRADIENT_6}",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "color": "${GRADIENT_8}",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "color": "${ACCENT}",
    "bold": true
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "color": "${SEM_WARN}",
    "italic": true
  },
  "strong": {
    "bold": true,
    "color": "${SEM_MATCH}"
  },
  "hr": {
    "color": "${SURFACE2}",
    "format": "─────"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "${SEM_LINK}",
    "underline": true
  },
  "link_text": {
    "color": "${SEM_INFO}",
    "bold": true
  },
  "image": {
    "color": "${SEM_LINK}",
    "underline": true
  },
  "image_text": {
    "color": "${ACCENT}",
    "format": "Image: {{.text}}"
  },
  "code": {
    "color": "${SEM_OK}",
    "background_color": "${CRUST}"
  },
  "code_block": {
    "color": "${TEXT}",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "${TEXT}"
      },
      "error": {
        "color": "${TEXT}",
        "background_color": "${SEM_ERR}"
      },
      "comment": {
        "color": "${SURFACE2}"
      },
      "comment_preproc": {
        "color": "${ACCENT}"
      },
      "keyword": {
        "color": "${ACCENT}"
      },
      "keyword_reserved": {
        "color": "${ACCENT}"
      },
      "keyword_namespace": {
        "color": "${SEM_ERR}"
      },
      "keyword_type": {
        "color": "${SEM_WARN}"
      },
      "operator": {
        "color": "${SEM_INFO}"
      },
      "punctuation": {
        "color": "${SUBTEXT0}"
      },
      "name": {
        "color": "${TEXT}"
      },
      "name_builtin": {
        "color": "${SEM_ERR}"
      },
      "name_tag": {
        "color": "${ACCENT}"
      },
      "name_attribute": {
        "color": "${SEM_WARN}"
      },
      "name_class": {
        "color": "${SEM_WARN}"
      },
      "name_constant": {
        "color": "${SEM_MATCH}"
      },
      "name_decorator": {
        "color": "${SEM_INFO}"
      },
      "name_exception": {
        "color": "${SEM_MATCH}"
      },
      "name_function": {
        "color": "${SEM_LINK}"
      },
      "name_other": {
        "color": "${TEXT}"
      },
      "literal": {
        "color": "${SEM_MATCH}"
      },
      "literal_number": {
        "color": "${SEM_MATCH}"
      },
      "literal_date": {
        "color": "${SEM_MATCH}"
      },
      "literal_string": {
        "color": "${SEM_OK}"
      },
      "literal_string_escape": {
        "color": "${ACCENT}"
      },
      "generic_deleted": {
        "color": "${SEM_ERR}"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "${SEM_OK}"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "${SEM_INFO}"
      },
      "background": {
        "background_color": "${MANTLE}"
      }
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
