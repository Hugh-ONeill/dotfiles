@base: ${BASE};
@mantle: ${MANTLE};
@crust: ${CRUST};
@accent: @mauve;

#lib {
  .palette() {}
  .defaults() {
    color-scheme: dark;
    ::selection {
      background-color: fade(@accent, 30%);
      color: @text;
    }
  }
  .css-variables() {}
}


