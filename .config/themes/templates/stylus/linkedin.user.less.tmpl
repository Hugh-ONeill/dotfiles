  // ============================================================
  // STRUCTURAL OVERRIDES
  // ============================================================

  // page-level backgrounds
  body,
  html {
    background-color: @crust !important;
    color: @text !important;
  }

  // artdeco components (older design system, still used in some pages)
  [class*="artdeco-card"] {
    background-color: @base !important;
    border-color: @surface0 !important;
  }

  [class*="artdeco-modal"],
  [class*="artdeco-dropdown__content"] {
    background-color: @base !important;
  }

  // inputs & search
  input,
  textarea,
  select {
    background-color: @surface0 !important;
    color: @text !important;
    border-color: @surface1 !important;
  }

  // scrollbar
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: @crust; }
  ::-webkit-scrollbar-thumb { background: @surface1; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: @surface2; }
}
