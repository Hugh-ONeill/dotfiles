/* ==UserStyle==
@name LinkedIn Custom
@namespace github.com/wiz/userstyles/linkedin
@homepageURL https://github.com/wiz/userstyles
@version 2026.02.19
@description Custom theme for LinkedIn
@author wiz
@license MIT

@preprocessor less
@var select lightFlavor "Light Flavor" ["latte:Latte*", "frappe:Frappé", "macchiato:Macchiato", "mocha:Mocha"]
