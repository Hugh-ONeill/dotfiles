    // ============================================================
    // SEMANTIC DESIGN TOKENS (newer Mercado design system)
    // ============================================================

    color-scheme: dark;

    // backgrounds
    --color-background-canvas: @crust;
    --color-background-container: @base;
    --color-background-container-tint: @mantle;
    --color-background-container-raised: @surface0;
