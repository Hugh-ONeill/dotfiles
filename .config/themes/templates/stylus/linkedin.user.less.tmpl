    --color-background-scrim: fade(@crust, 70%);
    --color-background-inverse: @text;
    --color-background-brand: @accent;
    --color-background-info: fade(@blue, 15%);
    --color-background-warning: fade(@yellow, 15%);
    --color-background-danger: fade(@red, 15%);
    --color-background-success: fade(@green, 15%);
    --color-background-disabled: @surface0;

    // text
    --color-text: @text;
    --color-text-primary: @text;
    --color-text-secondary: @subtext0;
    --color-text-low-emphasis: @subtext1;
    --color-text-disabled: @overlay1;
    --color-text-on-dark: @text;
    --color-text-on-brand: @crust;
    --color-text-brand: @accent;
    --color-text-link: @blue;
    --color-text-link-visited: @lavender;
    --color-text-info: @blue;
    --color-text-success: @green;
    --color-text-warning: @yellow;
    --color-text-danger: @red;
    --color-text-inverse: @crust;

    // borders
    --color-border: @surface1;
    --color-border-low-emphasis: @surface0;
    --color-border-medium-emphasis: @surface1;
    --color-border-high-emphasis: @surface2;
    --color-border-focus: @accent;
    --color-border-brand: @accent;
    --color-border-inverse: @text;

    // actions & interactive
    --color-action: @accent;
    --color-action-hover: darken(@accent, 5%);
    --color-action-pressed: darken(@accent, 10%);
    --color-action-disabled: @overlay0;
    --color-element: @crust;
    --color-icon-on-dark: @text;
    --color-scrim: fade(@crust, 40%);
    --color-signal-positive: @accent;
    --color-checked: @accent;
    --color-checked-hover: @accent;
    --color-checked-active: @accent;

    // component-level tokens
    --voyager-color-background-badge-notification: @accent;
    --artdeco-button-secondary-default-hover-background-color: fade(@blue, 20%);

    // codeblock fixes
    pre {
      --color-text-on-dark: @text;
      --color-background-container-dark-tint: @crust;
    }

