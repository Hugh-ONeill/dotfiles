{
  // NOTE: This is a template file. Run generate-theme.sh to create config.jsonc
  // ============================================================
  // WAYBAR CONFIGURATION
  // ============================================================

  // Bar Settings
  "layer": "top",
  "position": "top",
  "mode": "dock",
  //"height": 24, // uncomment to set fixed height
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "reload_style_on_change": true,
  "output": [
    "eDP-1",
    "HDMI-A-1"
  ],

  // ============================================================
  // MODULE LAYOUT
  // ============================================================
  // Left: Workspaces & Window Title
  "modules-left": [
    "custom/ws",
    "custom/left-ws-workspaces",
    "hyprland/workspaces",
    "custom/right-workspaces-window",
    "hyprland/window"
  ],
  // Center: System Stats, Clock, Network
  "modules-center": [
    "custom/left-bar-fans",
    "custom/fans",
    "custom/left-fans-temp",
    "custom/temp",
    "custom/left-temp-gpu",
    "custom/gpu",
    "custom/left-gpu-memory",
    "memory",
    "custom/left-memory-cpu",
    "cpu",
    "custom/leftin-cpu-idle",
    "custom/left-idle-center",
    "idle_inhibitor",
    "custom/right-center-clock",
    "custom/rightin-clock-time",
    "clock#time",
    "custom/right-time-date",
    "clock#date",
    "custom/right-date-pomodoro",
    "custom/pomodoro",
    "custom/right-pomodoro-bluetooth",
    "bluetooth",
    "custom/right-bluetooth-wifi",
    "custom/wifi",
    "custom/right-wifi-end"
  ],
  // Right: Audio, Brightness, Battery, Power
  "modules-right": [
    //"custom/media",
    "custom/cava",
    "custom/left-cava-audio",
    "pulseaudio",
    "custom/left-audio-backlight",
    "backlight",
    "custom/left-backlight-battery",
    "custom/battery",
    "custom/leftin-battery-power",
    "custom/power"
  ],

  // ============================================================
  // MODULE DEFINITIONS
  // ============================================================

  // -------------------- Left Panel --------------------
  // Window Icon
  "custom/ws": {
    "format": " 󰯉 ",
    "tooltip": false,
    "min-length": 3,
    "max-length": 3
  },

  // Workspaces
  "hyprland/workspaces": {
    "format": "{name}",
    "all-outputs": false,
    "active-only": false,
    "on-click": "activate",
    "disable-scroll": false,
    "on-scroll-up": "~/.config/waybar/scripts/workspace-scroll.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/workspace-scroll.sh down",
    "persistent-workspaces": {
      "eDP-1": [
        1,
        3,
        5,
        7,
        9
      ],
      "HDMI-A-1": [
        2,
        4,
        6,
        8,
        10
      ]
    },
    "sort-by-number": true,
    "tooltip": false
  },

  // Window Title with App Icons
  "hyprland/window": {
    "format": " {}",
    "separate-outputs": true,
    "rewrite": {
      // desktop
      "": "<span foreground='${OVERLAY1}'> </span> Hyprland",
      // terminals
      "(.*)kitty": "<span foreground='${OVERLAY1}'> </span> kitty",
      // editors
      "(.*) - Visual Studio Code": "<span foreground='${OVERLAY1}'> </span> $1",
      "(.*)Visual Studio Code": "<span foreground='${OVERLAY1}'> </span> Visual Studio Code",
      "(.*) - N?VIM": "<span foreground='#57a143'> </span> $1",
      "(.*)N?VIM": "<span foreground='#57a143'> </span> Neovim",
      // browsers
      "(.*) — Mozilla Firefox": "<span foreground='#e45b30'> </span> $1",
      "(.*)Mozilla Firefox": "<span foreground='#e45b30'> </span> Firefox",
      // media
      "(.*)Spotify(.*)": "<span foreground='#1db954'> </span> Spotify",
      "(.*)mpv": "<span foreground='${OVERLAY1}'> </span> mpv",
      // communication
      "vesktop": "<span foreground='#5865f2'> </span> Discord",
      "• Discord(.*)": "Discord$1",
      "(.*)Discord(.*)": "<span foreground='#5865f2'> </span> $1Discord$2",
      // creative
      "OBS(.*)": "<span foreground='${TEXT}'> </span> OBS Studio",
      "VLC media player": "<span foreground='#e09070'> </span> VLC Media Player",
      "(.*) - VLC media player": "<span foreground='#e09070'> </span> $1",
      "GNU Image Manipulation Program": "<span foreground='${TEXT}'> </span> GIMP",
      "Godot": "<span foreground='#478cbf'> </span> Godot Engine",
      "Godot Engine - (.*)": "<span foreground='#478cbf'> </span> $1",
      "(.*) - Godot Engine": "<span foreground='#478cbf'> </span> $1",
      // office
      "Office": "<span foreground='${RED}'> </span> Desktop Editor",
      "(.*).docx": "<span foreground='#2b579a'> </span> $1.docx",
      "(.*).xlsx": "<span foreground='#217346'> </span> $1.xlsx",
      "(.*).pptx": "<span foreground='#d24726'> </span> $1.pptx",
      "(.*).pdf": "<span foreground='${RED}'> </span> $1.pdf",
      // file manager
      "/": "<span foreground='${YELLOW}'> </span> File Manager",
      // images
      "(.*).jpg": "<span foreground='${FT_MEDIA}'>󰈟 </span> $1.jpg",
      "(.*).png": "<span foreground='${FT_MEDIA}'>󰈟 </span> $1.png",
      "(.*).svg": "<span foreground='${FT_MEDIA}'>󰈟 </span> $1.svg",
      "(.*).webp": "<span foreground='${FT_MEDIA}'>󰈟 </span> $1.webp",
      "(.*).gif": "<span foreground='${FT_MEDIA}'>󰈟 </span> $1.gif",
      // archives
      "(.*).zip": "<span foreground='${FT_ARCHIVE}'> </span> $1.zip",
      "(.*).tar(.*)": "<span foreground='${FT_ARCHIVE}'> </span> $1.tar$2",
      "(.*).7z": "<span foreground='${FT_ARCHIVE}'> </span> $1.7z",
      "(.*).rar": "<span foreground='${FT_ARCHIVE}'> </span> $1.rar",
      // code - brand colors
      "(.*).py": "<span foreground='#3776ab'> </span> $1.py",
      "(.*).js": "<span foreground='#f7df1e'> </span> $1.js",
      "(.*).ts": "<span foreground='#3178c6'> </span> $1.ts",
      "(.*).rs": "<span foreground='#dea584'> </span> $1.rs",
      "(.*).go": "<span foreground='#00add8'> </span> $1.go",
      "(.*).c": "<span foreground='#a8b9cc'> </span> $1.c",
      "(.*).cpp": "<span foreground='#00599c'> </span> $1.cpp",
      "(.*).lua": "<span foreground='#000080'> </span> $1.lua",
      "(.*).sh": "<span foreground='#4eaa25'> </span> $1.sh",
      // text
      "(.*).txt": "<span foreground='${OVERLAY1}'> </span> $1.txt",
      "(.*).md": "<span foreground='${OVERLAY1}'> </span> $1.md",
      "(.*).json": "<span foreground='${FT_DATA}'> </span> $1.json",
      "(.*).yaml": "<span foreground='${FT_DATA}'> </span> $1.yaml",
      "(.*).toml": "<span foreground='${FT_DATA}'> </span> $1.toml"
    },
    "min-length": 5,
    "max-length": 45
  },

  // -------------------- Center Panel --------------------
  // Fan Speed Monitor
  "custom/fans": {
    "exec": "~/.config/waybar/scripts/fanspeed.sh",
    "return-type": "json",
    "format": "󰈐 {}",
    "tooltip": true,
    "on-scroll-up": "~/.config/waybar/scripts/fancontrol.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/fancontrol.sh down",
    "on-click": "~/.config/waybar/scripts/fancontrol.sh auto",
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // CPU Temperature
  "custom/temp": {
    "exec": "~/.config/waybar/scripts/cpuinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // GPU Usage
  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpuinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // Memory Usage
  "memory": {
    "states": {
      "warning": 75,
      "critical": 90
    },
    "format": "󰘚 {percentage:>2}%",
    "format-critical": " {percentage:>2}%",
    "tooltip": true,
    "tooltip-format": "Memory Used: {used:0.1f} GB / {total:0.1f} GB",
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // CPU Usage
  "cpu": {
    "format": " {usage:>2}%",
    "format-icons": [
      "▁",
      "▂",
      "▃",
      "▄",
      "▅",
      "▆",
      "▇",
      "█"
    ],
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // Game Mode Toggle
  "idle_inhibitor": {
    "on-click": "~/.local/bin/gamemode.sh",
    "format": " {icon} ",
    "format-icons": {
      "activated": "󰊠",
      "deactivated": "󱙝"
    },
    "justify": "center",
    "tooltip": true,
    "tooltip-format-activated": "Game Mode",
    "tooltip-format-deactivated": "Normal Mode",
    "start-activated": false,
    "timeout": -1
  },

  // Clock - Time
  "clock#time": {
    "format": "󱑂 {:%H:%M}",
    "tooltip": true,
    "tooltip-format": "12-hour Format: {:%I:%M %p}",
    "min-length": 8,
    "max-length": 8
  },

  // Clock - Date
  "clock#date": {
    "format": "󰨳 {:%m-%d}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 6,
      "on-click-right": "mode",
      "format": {
        "today": "<span color='${SURFACE1}'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode"
    },
    "min-length": 8,
    "max-length": 8
  },

  // Pomodoro Timer
  "custom/pomodoro": {
    "return-type": "json",
    "format": "{}",
    "exec": "~/.config/waybar/scripts/pomodoro.sh",
    "on-click": "~/.config/waybar/scripts/pomodoro.sh toggle",
    "on-click-middle": "~/.config/waybar/scripts/pomodoro.sh close",
    "on-click-right": "~/.config/waybar/scripts/pomodoro.sh reset",
    "interval": 1,
    "min-length": 8,
    "max-length": 8
  },

  // Bluetooth
  "bluetooth": {
    "format": " {status}",
    "format-connected": " {device_alias}",
    "format-connected-battery": " {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueman-manager",
    "min-length": 8,
    "max-length": 8
  },

  // WiFi Connection
  "custom/wifi": {
    "exec": "~/.config/waybar/scripts/wifiinfo.sh",
    "return-type": "json",
    "format": "{}", // in wifiinfo.sh, change "Wi-Fi" to "${essid}" to display network name
    "tooltip": true,
    "on-click": "pkill -x rofi || ~/.config/rofi/network/network.sh",
    "interval": 10,
    "min-length": 8,
    "max-length": 8
  },

  // -------------------- Right Panel --------------------
  // Audio Visualizer (Cava)
  "custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "format": "{}",
    "tooltip": false,
    "on-click": "pkill -f cava || ~/.config/waybar/scripts/cava.sh",
    "min-length": 10,
    "max-length": 10
  },

  // Media Player (optional)
  //"custom/media": {
  //  "exec": "/usr/bin/python3 ~/.config/waybar/scripts/mediaplayer.py",
  //  "return-type": "json",
  //  "format": "{}",
  //  "tooltip": "{tooltip}",
  //  "on-click": "playerctl play-pause",
  //  "min-length": 5,
  //  "max-length": 35
  //},

  // Audio Control
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 {volume}%",
    "format-icons": {
      "headphone": "󰋋",
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "tooltip-format": "{icon} {desc} // {volume}%",
    "on-click": "hyprpwcenter",
    "on-click-right": "~/.local/bin/volumecontrol.sh -s ''",
    "on-click-middle": "~/.local/bin/volumecontrol.sh -o m",
    "on-scroll-up": "~/.local/bin/volumecontrol.sh -o i",
    "on-scroll-down": "~/.local/bin/volumecontrol.sh -o d",
    "min-length": 6,
    "max-length": 6
  },

  // Screen Brightness
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "󱩎",
      "󱩏",
      "󱩐",
      "󱩑",
      "󱩒",
      "󱩓",
      "󱩔",
      "󱩕",
      "󱩖"
    ],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
  },

  // Battery Status
  "custom/battery": {
    "exec": "~/.config/waybar/scripts/batteryinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 30,
    "min-length": 6,
    "max-length": 6
  },

  // Power Menu
  "custom/power": {
    "format": "󰐥",
    "tooltip": false,
    "on-click": "~/.local/bin/logoutlaunch.sh 2",
    "on-click-right": "~/.local/bin/logoutlaunch.sh 1",
    "interval": 86400
  },

  // ============================================================
  // VISUAL SEPARATORS (Powerline Arrows)
  // ============================================================
  // Left Separators — fg color fills right side of glyph
  "custom/left-ws-workspaces": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-bar-fans": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-temp-gpu": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-memory-cpu": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-idle-center": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-cava-audio": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-audio-backlight": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-backlight-battery": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-fans-temp": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/left-gpu-memory": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  // Right Separators — fg color fills left side of glyph
  "custom/right-workspaces-window": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-center-clock": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-time-date": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-date-pomodoro": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-wifi-end": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-pomodoro-bluetooth": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  "custom/right-bluetooth-wifi": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
  // Left Inverse (same glyph direction as left)
  "custom/leftin-cpu-idle": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  "custom/leftin-battery-power": {
    "format": "${WAYBAR_SEP_LEFT}",
    "tooltip": false
  },
  // Right Inverse (same glyph direction as right)
  "custom/rightin-clock-time": {
    "format": "${WAYBAR_SEP_RIGHT}",
    "tooltip": false
  },
}
