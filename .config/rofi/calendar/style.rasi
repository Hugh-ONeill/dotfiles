/* vim:ft=css */

@import "../shared/colors.rasi"
@import "../shared/fonts.rasi"

/* ══════════════════════════════════════════════════════════════════════════════
 * Window
 * ══════════════════════════════════════════════════════════════════════════════ */

* {
    background-color: transparent;
    text-color:       @foreground;
}

window {
    location:         center;
    anchor:           center;
    width:            380px;
    background-color: transparent;
}

/* ══════════════════════════════════════════════════════════════════════════════
 * Main Layout
 * ══════════════════════════════════════════════════════════════════════════════ */

mainbox {
    spacing:          12px;
    padding:          20px;
    border:           2px solid;
    border-color:     @g8;
    border-radius:    12px;
    background-color: @background;
    children:         [ "inputbar", "listview" ];
}

/* ══════════════════════════════════════════════════════════════════════════════
 * Input Bar (Month/Year header)
 * ══════════════════════════════════════════════════════════════════════════════ */

inputbar {
    children: [ "prompt" ];
}

prompt {
    padding:          12px 18px;
    border-radius:    8px;
    background-color: @g8;
    text-color:       @crust;
    horizontal-align: 0.5;
}

/* ══════════════════════════════════════════════════════════════════════════════
 * List View (7-column grid)
 * ══════════════════════════════════════════════════════════════════════════════ */

listview {
    lines:        8;
    columns:      7;
    flow:         horizontal;
    spacing:      4px;
    scrollbar:    false;
    fixed-height: false;
    dynamic:      true;
}

/* ══════════════════════════════════════════════════════════════════════════════
 * Elements
 * ══════════════════════════════════════════════════════════════════════════════ */

element {
    padding:          10px 2px;
    border-radius:    6px;
    cursor:           pointer;
    horizontal-align: 0.5;
}

element-text {
    horizontal-align: 0.5;
    expand:           true;
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
}

element selected.normal {
    background-color: @g8;
    text-color:       @crust;
}

element-text selected {
    text-color: @crust;
}

/* Current day highlight */
element normal.active,
element alternate.active {
    background-color: @surface1;
    text-color:       @g8;
}

element selected.active {
    background-color: @g8;
    text-color:       @crust;
}

element-text active {
    text-color: inherit;
}
