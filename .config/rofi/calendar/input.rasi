/* vim:ft=css */

@import "../shared/colors.rasi"
@import "../shared/fonts.rasi"

* {
    background-color: transparent;
    text-color:       @foreground;
}

window {
    transparency:     "real";
    location:         center;
    anchor:           center;
    width:            400px;
    border:           2px solid;
    border-color:     @lavender;
    border-radius:    12px;
    background-color: @background;
}

mainbox {
    spacing:  12px;
    padding:  20px;
    children: [ "inputbar", "listview" ];
}

inputbar {
    spacing:  10px;
    children: [ "prompt", "entry" ];
}

prompt {
    padding:          12px 16px;
    border-radius:    8px;
    background-color: @teal;
    text-color:       @crust;
}

entry {
    padding:           12px;
    border-radius:     8px;
    background-color:  @surface0;
    text-color:        @foreground;
    placeholder:       "Type here...";
    placeholder-color: @overlay0;
}

listview {
    lines:   1;
    columns: 1;
    spacing: 4px;
}

element {
    padding:       10px 14px;
    border-radius: 6px;
}

element normal.normal {
    background-color: @surface0;
}

element selected.normal {
    background-color: @teal;
    text-color:       @crust;
}

element-text selected {
    text-color: @crust;
}
