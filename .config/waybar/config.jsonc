{
  // NOTE: This is a template file. Run generate-config.sh to create config.jsonc
  // ============================================================
  // WAYBAR CONFIGURATION
  // ============================================================

  // Bar Settings
  "layer": "top",
  "position": "top",
  "mode": "dock",
  //"height": 24, // uncomment to set fixed height
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "reload_style_on_change": true,
  "output": [
    "eDP-1",
    "HDMI-A-1"
  ],

  // ============================================================
  // MODULE LAYOUT
  // ============================================================
  // Left: Workspaces & Window Title
  "modules-left": [
    "custom/ws",
    "custom/left1",
    "hyprland/workspaces",
    "custom/right1",
    "hyprland/window"
  ],
  // Center: System Stats, Clock, Network
  "modules-center": [
    "custom/left2",
    "custom/fans",
    "custom/left9",
    "custom/temp",
    "custom/left3",
    "custom/gpu",
    "custom/left10",
    "memory",
    "custom/left4",
    "cpu",
    "custom/leftin1",
    "custom/left5",
    "idle_inhibitor",
    "custom/right2",
    "custom/rightin1",
    "clock#time",
    "custom/right3",
    "clock#date",
    "custom/right4",
    "custom/pomodoro",
    "custom/right6",
    "bluetooth",
    "custom/right7",
    "custom/wifi",
    "custom/right5"
  ],
  // Right: Audio, Brightness, Battery, Power
  "modules-right": [
    //"custom/media",
    "custom/left6",
    "pulseaudio",
    "custom/left7",
    "backlight",
    "custom/left8",
    "custom/battery",
    "custom/leftin2",
    "custom/power"
  ],

  // ============================================================
  // MODULE DEFINITIONS
  // ============================================================

  // -------------------- Left Panel --------------------
  // Window Icon
  "custom/ws": {
    "format": " ґ░пЙ ",
    "tooltip": false,
    "min-length": 3,
    "max-length": 3
  },

  // Workspaces
  "hyprland/workspaces": {
    "format": "{name}",
    "all-outputs": false,
    "active-only": false,
    "on-click": "activate",
    "disable-scroll": false,
    "on-scroll-up": "~/.config/waybar/scripts/workspace-scroll.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/workspace-scroll.sh down",
    "persistent-workspaces": {
      "eDP-1": [
        1,
        3,
        5,
        7,
        9
      ],
      "HDMI-A-1": [
        2,
        4,
        6,
        8,
        10
      ]
    },
    "sort-by-number": true,
    "tooltip": false
  },

  // Window Title with App Icons
  "hyprland/window": {
    "format": "{}",
    "separate-outputs": true,
    "rewrite": {
      // desktop
      "": "<span foreground='#9088b0'>яНЩ </span> Hyprland",
      // terminal
      "wiz@grimoire:(.*)": "яТЙ  $1",
      "(.*)wiz@grimoire:~": "яТЙ  wiz@grimoire",
      // Firefox
      "(.*) тАФ Mozilla Firefox": "<span foreground='#d06050'>ґ░И╣ </span> $1",
      "(.*)Mozilla Firefox": "<span foreground='#d06050'>ґ░И╣ </span> Firefox",
      // VSCode
      "(.*) - Visual Studio Code": "<span foreground='#9088b0'>ґ░иЮ </span> $1",
      "(.*)Visual Studio Code": "<span foreground='#9088b0'>ґ░иЮ </span> Visual Studio Code",
      // Spotify
      "(.*)Spotify": "<span foreground='#d8c078'>яЖ╝ </span> Spotify",
      "(.*)Spotify Premium": "<span foreground='#d8c078'>яЖ╝ </span> Spotify Premium",
      // Discord
      "vesktop": "<span foreground='#9088b0'>яЗ┐ </span> Discord",
      "тАв Discord(.*)": "Discord$1",
      "(.*)Discord(.*)": "<span foreground='#9088b0'>яЗ┐ </span> $1Discord$2",
      // OBS Studio
      "OBS(.*)": "<span foreground='#f4ebe4'>ґ░РМ </span> OBS Studio",
      // VLC Media Player
      "VLC media player": "<span foreground='#e09070'>ґ░Х╝ </span> VLC Media Player",
      "(.*) - VLC media player": "<span foreground='#e09070'>ґ░Х╝ </span> $1",
      // GIMP
      "GNU Image Manipulation Program": "<span foreground='#f4ebe4'>яМ╕ </span> GNU Image Manipulation Program",
      // Godot
      "Godot": "<span foreground='#9088b0'>юЩЯ </span> Godot Engine",
      "Godot Engine - (.*)": "<span foreground='#9088b0'>юЩЯ </span> $1",
      "(.*) - Godot Engine": "<span foreground='#9088b0'>юЩЯ </span> $1",
      // Office Desktop Editors
      "Office": "<span foreground='#d06050'>ю║и </span> Desktop Editor",
      "(.*).docx": "<span foreground='#9088b0'>яЗВ </span> $1.docx",
      "(.*).xlsx": "<span foreground='#d8c078'>яЗГ </span> $1.xlsx",
      "(.*).pptx": "<span foreground='#e09070'>яЗД </span> $1.pptx",
      "(.*).pdf": "<span foreground='#d06050'>яЗБ </span> $1.pdf",
      // file manager
      "/": "юл╖  File Manager",
      // qView
      //"qView": "яА╛  qView",
      "(.*).jpg": "яА╛  $1.jpg",
      "(.*).png": "яА╛  $1.png",
      "(.*).svg": "яА╛  $1.svg"
      // Timeshift
      //"Timeshift-gtk": "<span foreground='#d8c078'>яФР </span> Timeshift",
      // security
      //"Authenticate": "яТЬ  Authenticate"
    },
    "min-length": 5,
    "max-length": 45
  },

  // -------------------- Center Panel --------------------
  // Fan Speed Monitor
  "custom/fans": {
    "exec": "~/.config/waybar/scripts/fanspeed.sh",
    "return-type": "json",
    "format": "яЬП {}",
    "tooltip": true,
    "on-scroll-up": "~/.config/waybar/scripts/fancontrol.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/fancontrol.sh down",
    "on-click": "~/.config/waybar/scripts/fancontrol.sh auto",
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // CPU Temperature
  "custom/temp": {
    "exec": "~/.config/waybar/scripts/cpuinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // GPU Usage
  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpuinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // Memory Usage
  "memory": {
    "states": {
      "warning": 75,
      "critical": 90
    },
    "format": "ґ░НЫ {percentage:>2}%",
    "format-critical": "яБ▒ {percentage:>2}%",
    "tooltip": true,
    "tooltip-format": "Memory Used: {used:0.1f} GB / {total:0.1f} GB",
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // CPU Usage
  "cpu": {
    "format": "юЙж {usage:>2}%",
    "format-icons": [
      "тЦБ",
      "тЦВ",
      "тЦГ",
      "тЦД",
      "тЦЕ",
      "тЦЖ",
      "тЦЗ",
      "тЦИ"
    ],
    "tooltip": true,
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // Game Mode Toggle
  "idle_inhibitor": {
    "on-click": "~/.local/bin/gamemode.sh",
    "format": " {icon} ",
    "format-icons": {
      "activated": "ґ░Ка",
      "deactivated": "ґ▒ЩЭ"
    },
    "justify": "center",
    "tooltip": true,
    "tooltip-format-activated": "Game Mode",
    "tooltip-format-deactivated": "Normal Mode",
    "start-activated": false,
    "timeout": -1
  },

  // Clock - Time
  "clock#time": {
    "format": "ґ▒СВ {:%H:%M}",
    "tooltip": true,
    "tooltip-format": "12-hour Format: {:%I:%M %p}",
    "min-length": 8,
    "max-length": 8
  },

  // Clock - Date
  "clock#date": {
    "format": "ґ░и│ {:%m-%d}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 6,
      "on-click-right": "mode",
      "format": {
        "today": "<span color='#4a4a5e'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode"
    },
    "min-length": 8,
    "max-length": 8
  },

  // Pomodoro Timer
  "custom/pomodoro": {
    "return-type": "json",
    "format": "{}",
    "exec": "~/.config/waybar/scripts/pomodoro.sh",
    "on-click": "~/.config/waybar/scripts/pomodoro.sh toggle",
    "on-click-middle": "~/.config/waybar/scripts/pomodoro.sh close",
    "on-click-right": "~/.config/waybar/scripts/pomodoro.sh reset",
    "interval": 1,
    "min-length": 8,
    "max-length": 8
  },

  // Bluetooth
  "bluetooth": {
    "format": "яКФ {status}",
    "format-connected": "яКФ {device_alias}",
    "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueman-manager",
    "min-length": 8,
    "max-length": 8
  },

  // WiFi Connection
  "custom/wifi": {
    "exec": "~/.config/waybar/scripts/wifiinfo.sh",
    "return-type": "json",
    "format": "{}", // in wifiinfo.sh, change "Wi-Fi" to "${essid}" to display network name
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/wifimenu.sh",
    "interval": 10,
    "min-length": 8,
    "max-length": 8
  },

  // -------------------- Right Panel --------------------
  // Media Player (optional)
  //"custom/media": {
  //  "exec": "/usr/bin/python3 ~/.config/waybar/scripts/mediaplayer.py",
  //  "return-type": "json",
  //  "format": "{}",
  //  "tooltip": "{tooltip}",
  //  "on-click": "playerctl play-pause",
  //  "min-length": 5,
  //  "max-length": 35
  //},

  // Audio Control
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "ґ░ЭЯ {volume}%",
    "format-icons": {
      "headphone": "ґ░ЛЛ",
      "default": [
        "ґ░Х┐",
        "ґ░ЦА",
        "ґ░Х╛"
      ]
    },
    "tooltip-format": "{icon} {desc} // {volume}%",
    "on-click": "pavucontrol -t 3",
    "on-click-right": "~/.local/bin/volumecontrol.sh -s ''",
    "on-click-middle": "~/.local/bin/volumecontrol.sh -o m",
    "on-scroll-up": "~/.local/bin/volumecontrol.sh -o i",
    "on-scroll-down": "~/.local/bin/volumecontrol.sh -o d",
    "min-length": 6,
    "max-length": 6
  },

  // Screen Brightness
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "юОН",
      "юПУ",
      "юПС",
      "юПП",
      "юПО",
      "юПН",
      "юПК",
      "юПИ",
      "юОЫ"
    ],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
  },

  // Battery Status
  "custom/battery": {
    "exec": "~/.config/waybar/scripts/batteryinfo.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 30,
    "min-length": 6,
    "max-length": 6
  },

  // Power Menu
  "custom/power": {
    "format": "<span color='#4a4a5e'>яАС</span> ",
    "tooltip": false,
    "on-click": "~/.local/bin/logoutlaunch.sh 2",
    "on-click-right": "~/.local/bin/logoutlaunch.sh 1",
    "interval": 86400
  },

  // ============================================================
  // VISUAL SEPARATORS (Powerline Arrows)
  // ============================================================
  // Left Arrows (тЖТ)
  "custom/left1": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left2": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left3": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left4": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left5": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left6": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left7": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left8": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left9": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/left10": {
    "format": "юВ╢",
    "tooltip": false
  },
  // Right Arrows
  "custom/right1": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right2": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right3": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right4": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right5": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right6": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right7": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/right8": {
    "format": "юВ┤",
    "tooltip": false
  },
  // Left Inverse
  "custom/leftin1": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/leftin2": {
    "format": "юВ╢",
    "tooltip": false
  },
  "custom/leftin3": {
    "format": "юВ╢юГЦ",
    "tooltip": false
  },
  // Right Inverse
  "custom/rightin1": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/rightin2": {
    "format": "юВ┤",
    "tooltip": false
  },
  "custom/rightin3": {
    "format": "юГЧюВ┤",
    "tooltip": false
  }
}
