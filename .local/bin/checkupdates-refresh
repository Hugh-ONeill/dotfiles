#!/bin/bash
# Refresh cached update count
# Run periodically via systemd timer or pacman hook

# Get the real user's home (even when run as root via pacman hook)
if [[ -n "$SUDO_USER" ]]; then
    real_home=$(getent passwd "$SUDO_USER" | cut -d: -f6)
elif [[ $EUID -eq 0 ]]; then
    # Fallback: hardcode if running as root without SUDO_USER
    real_home="/home/wiz"
else
    real_home="$HOME"
fi

cache_file="$real_home/.cache/checkupdates-count"

# Count available updates (pacman + AUR if paru/yay available)
count=0

# Official repos
if command -v checkupdates &>/dev/null; then
    count=$(checkupdates 2>/dev/null | wc -l)
fi

# AUR updates (paru or yay)
if command -v paru &>/dev/null; then
    aur_count=$(paru -Qua 2>/dev/null | wc -l)
    count=$((count + aur_count))
elif command -v yay &>/dev/null; then
    aur_count=$(yay -Qua 2>/dev/null | wc -l)
    count=$((count + aur_count))
fi

echo "$count" > "$cache_file"
