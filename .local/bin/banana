#!/usr/bin/env python3
"""Spinning ASCII banana — single or bunch mode with interactive TUI controls."""

import math
import select
import sys
import termios
import time
import tty

SCREEN_W, SCREEN_H = 80, 40
FILL_CHAR = '\u2588'  # █ full block
CAM_DIST = 12

# Colors (R, G, B)
BG_COLOR = (18, 18, 28)
SHADOW_COLOR = (10, 10, 18)
BORDER_COLOR = (220, 180, 40)
YELLOW = (255, 220, 50)
BROWN = (150, 100, 50)
TIP_BLEND_START = 0.75

# Light from the left and slightly above/in front
LIGHT_DIR = (-0.75, 0.4, 0.5)
GROUND_Y = -2.2


def lerp_color(c1, c2, f):
    return (
        int(c1[0] + (c2[0] - c1[0]) * f),
        int(c1[1] + (c2[1] - c1[1]) * f),
        int(c1[2] + (c2[2] - c1[2]) * f),
    )


def shade_color(base, lum):
    ambient = 0.4
    f = ambient + (1 - ambient) * lum
    return (int(base[0] * f), int(base[1] * f), int(base[2] * f))


def rotate_point(px, py, pz, sa, ca, sb, cb, sc, cc):
    """Ry then Rx then Rz."""
    x1 = cb * px + sb * pz
    y1 = py
    z1 = -sb * px + cb * pz
    x2 = x1
    y2 = ca * y1 - sa * z1
    z2 = sa * y1 + ca * z1
    x3 = cc * x2 - sc * y2
    y3 = sc * x2 + cc * y2
    return x3, y3, z2


def rot_x(px, py, pz, angle):
    c, s = math.cos(angle), math.sin(angle)
    return (px, c * py - s * pz, s * py + c * pz)


def rot_y(px, py, pz, angle):
    c, s = math.cos(angle), math.sin(angle)
    return (c * px + s * pz, py, -s * px + c * pz)


def rot_z(px, py, pz, angle):
    c, s = math.cos(angle), math.sin(angle)
    return (c * px - s * py, s * px + c * py, pz)


def make_single_banana():
    """Generate one banana centered at origin, upright (tip-to-tip in Y)."""
    points = []
    normals = []
    t_values = []
    N_SPINE = 80
    N_RING = 40

    for i in range(N_SPINE):
        t = -1 + 2 * i / (N_SPINE - 1)
        arc = t * math.pi / 3
        sx = 2 * math.sin(arc)
        sz = 2 * math.cos(arc)

        tx, tz = math.cos(arc), -math.sin(arc)
        nx, nz = -math.sin(arc), -math.cos(arc)
        cross_y = tz * nx - tx * nz
        bx, by, bz = 0.0, cross_y, 0.0

        r = 0.45 * (1 - 0.75 * t * t)

        for j in range(N_RING):
            theta = 2 * math.pi * j / N_RING
            ct, st = math.cos(theta), math.sin(theta)

            px = sx + r * (ct * nx + st * bx)
            py = 0  + r * (ct * 0  + st * by)
            pz = sz + r * (ct * nz + st * bz)

            nnx = ct * nx + st * bx
            nny = ct * 0  + st * by
            nnz = ct * nz + st * bz

            # Reorient: tip-to-tip vertical, curve bends in X
            points.append((pz, px, py))
            normals.append((nnz, nnx, nny))
            t_values.append(t)

    # Recenter
    cx = sum(p[0] for p in points) / len(points)
    cy = sum(p[1] for p in points) / len(points)
    cz = sum(p[2] for p in points) / len(points)
    points = [(p[0] - cx, p[1] - cy, p[2] - cz) for p in points]

    return points, normals, t_values


def make_bunch():
    """Create a bunch: 3 in back, 2 in front, all curving the same way."""
    base_pts, base_nrm, base_t = make_single_banana()

    all_points = []
    all_normals = []
    all_t = []

    positions = [
        (-0.9,  0.0,  -0.5, -0.15),   # back left, tilted forward
        (0.0,   0.0,  -0.5, -0.15),   # back center, tilted forward
        (0.9,   0.0,  -0.5, -0.15),   # back right, tilted forward
        (-0.45, 0.0,   0.5,  0.35),   # front left, tilted back
        (0.45,  0.0,   0.5,  0.35),   # front right, tilted back
    ]

    tilt_strength = 0.35

    for side, y_off, fwd, back_tilt in positions:
        side_tilt = -side * tilt_strength

        for k in range(len(base_pts)):
            px, py, pz = base_pts[k]
            nx, ny, nz = base_nrm[k]

            px, py, pz = rot_y(px, py, pz, math.pi / 2)
            nx, ny, nz = rot_y(nx, ny, nz, math.pi / 2)

            px, py, pz = rot_x(px, py, pz, back_tilt)
            nx, ny, nz = rot_x(nx, ny, nz, back_tilt)

            px, py, pz = rot_z(px, py, pz, side_tilt)
            nx, ny, nz = rot_z(nx, ny, nz, side_tilt)

            all_points.append((px + side, py + y_off, pz + fwd))
            all_normals.append((nx, ny, nz))
            all_t.append(base_t[k])

    return all_points, all_normals, all_t


def banana_color(t):
    abs_t = abs(t)
    if abs_t > TIP_BLEND_START:
        blend = (abs_t - TIP_BLEND_START) / (1 - TIP_BLEND_START)
        return lerp_color(YELLOW, BROWN, blend)
    return YELLOW


# Projection scales per mode
PROJ = {
    'single': (18, 9),
    'bunch':  (14, 7),
}


def render(points, normals, t_values, ax, ay, az, proj_scale):
    sa, ca = math.sin(ax), math.cos(ax)
    sb, cb = math.sin(ay), math.cos(ay)
    sc, cc = math.sin(az), math.cos(az)

    total = SCREEN_W * SCREEN_H
    char_buf = [' '] * total
    color_buf = [BG_COLOR] * total
    zbuf = [-1e9] * total
    hit = [False] * total

    sx_scale, sy_scale = proj_scale

    lx, ly, lz = LIGHT_DIR
    lmag = math.sqrt(lx*lx + ly*ly + lz*lz)
    lx, ly, lz = lx/lmag, ly/lmag, lz/lmag

    # Shadow pass
    for k in range(len(points)):
        px, py, pz = points[k]
        rx, ry, rz = rotate_point(px, py, pz, sa, ca, sb, cb, sc, cc)

        if ly > 0.01:
            t_ground = (ry - GROUND_Y) / ly
            shad_x = rx - lx * t_ground

            ssx = int(SCREEN_W / 2 + shad_x * sx_scale)
            ssy = int(SCREEN_H / 2 - GROUND_Y * sy_scale)

            for dy in range(2):
                for dx in range(2):
                    px2 = ssx + dx
                    py2 = ssy + dy
                    if 0 <= px2 < SCREEN_W and 0 <= py2 < SCREEN_H:
                        idx = py2 * SCREEN_W + px2
                        if not hit[idx]:
                            color_buf[idx] = SHADOW_COLOR
                            char_buf[idx] = FILL_CHAR
                            hit[idx] = True

    # Banana pass
    for k in range(len(points)):
        px, py, pz = points[k]
        rx, ry, rz = rotate_point(px, py, pz, sa, ca, sb, cb, sc, cc)
        nx, ny, nz = normals[k]
        rnx, rny, rnz = rotate_point(nx, ny, nz, sa, ca, sb, cb, sc, cc)

        if rnz < 0:
            continue

        ssx = int(SCREEN_W / 2 + rx * sx_scale)
        ssy = int(SCREEN_H / 2 - ry * sy_scale)

        lum = rnx * lx + rny * ly + rnz * lz
        lum = max(0.0, min(1.0, lum))
        base = banana_color(t_values[k])
        col = shade_color(base, lum)

        for dy in range(2):
            for dx in range(2):
                px2 = ssx + dx
                py2 = ssy + dy
                if 0 <= px2 < SCREEN_W and 0 <= py2 < SCREEN_H:
                    idx = py2 * SCREEN_W + px2
                    if rz > zbuf[idx] + 0.15:
                        zbuf[idx] = rz
                        color_buf[idx] = col
                        char_buf[idx] = FILL_CHAR
                        hit[idx] = True

    # Build output with border frame — dark bg everywhere
    parts = []
    bgr, bgg, bgb = BG_COLOR
    br, bg_, bb = BORDER_COLOR
    bdr = f'\033[38;2;{br};{bg_};{bb};48;2;{bgr};{bgg};{bgb}m'
    prev_r, prev_g, prev_b = -1, -1, -1

    horiz = '\u2500' * SCREEN_W

    # Top border
    parts.append(f'{bdr}\u256d{horiz}\u256e\n')

    for row in range(SCREEN_H):
        parts.append(f'{bdr}\u2502')
        for col in range(SCREEN_W):
            idx = row * SCREEN_W + col
            if hit[idx]:
                r, g, b = color_buf[idx]
                if (r, g, b) != (prev_r, prev_g, prev_b):
                    parts.append(f'\033[38;2;{r};{g};{b};48;2;{bgr};{bgg};{bgb}m')
                    prev_r, prev_g, prev_b = r, g, b
                parts.append(char_buf[idx])
            else:
                if (prev_r, prev_g, prev_b) != (bgr, bgg, bgb):
                    parts.append(f'\033[38;2;{bgr};{bgg};{bgb};48;2;{bgr};{bgg};{bgb}m')
                    prev_r, prev_g, prev_b = bgr, bgg, bgb
                parts.append(' ')
        prev_r, prev_g, prev_b = -1, -1, -1
        parts.append(f'{bdr}\u2502\n')

    # Divider between viewport and HUD
    parts.append(f'{bdr}\u251c{horiz}\u2524\n')

    parts.append('\033[0m')
    return ''.join(parts)


def read_key():
    if select.select([sys.stdin], [], [], 0)[0]:
        ch = sys.stdin.read(1)
        if ch == '\033':
            if select.select([sys.stdin], [], [], 0)[0]:
                ch2 = sys.stdin.read(1)
                if ch2 == '[' and select.select([sys.stdin], [], [], 0)[0]:
                    ch3 = sys.stdin.read(1)
                    return {'A': 'up', 'B': 'down', 'C': 'right', 'D': 'left'}.get(ch3)
            return 'esc'
        return ch
    return None


def pad_hud_line(visible_text, ansi_text, width):
    """Pad an ANSI-colored line to exactly `width` visible characters."""
    pad = width - len(visible_text)
    if pad > 0:
        return ansi_text + ' ' * pad
    return ansi_text[:len(ansi_text)]  # shouldn't truncate but safety


def draw_hud(mode, speed_x, speed_y, speed_z, paused):
    bgr, bgg, bgb = BG_COLOR
    br, bg_, bb = BORDER_COLOR
    bdr = f'\033[38;2;{br};{bg_};{bb};48;2;{bgr};{bgg};{bgb}m'
    bg_on = f'\033[0;48;2;{bgr};{bgg};{bgb}m'

    k = f'\033[38;2;220;180;40m'   # yellow for keys
    t = f'\033[38;2;140;140;160m'  # muted for labels
    v = f'\033[38;2;120;220;230m'  # bright cyan for values

    state_txt = " PAUSED " if paused else " PLAYING"
    state_ansi = f"\033[38;2;255;200;80m{state_txt}{bg_on}" if paused else f"\033[38;2;100;220;120m{state_txt}{bg_on}"
    label = "BANANA" if mode == 'single' else " BUNCH"

    vis1 = f' {label}  {state_txt}    X:{speed_x:+.2f}  Y:{speed_y:+.2f}  Z:{speed_z:+.2f}'
    ansi1 = (
        f' \033[1;33m{label}{bg_on}  {state_ansi}'
        f'    {t}X:{v}{speed_x:+.2f}{bg_on}'
        f'  {t}Y:{v}{speed_y:+.2f}{bg_on}'
        f'  {t}Z:{v}{speed_z:+.2f}{bg_on}'
    )

    vis2 = ' Q/W X  A/S Y  Z/X Z  SPACE pause  R reset  TAB mode  Ctrl-C quit'
    ansi2 = (
        f' {k}Q/W {t}X  '
        f'{k}A/S {t}Y  '
        f'{k}Z/X {t}Z  '
        f'{k}SPACE {t}pause  '
        f'{k}R {t}reset  '
        f'{k}TAB {t}mode  '
        f'{k}Ctrl-C {t}quit'
    )

    horiz = '\u2500' * SCREEN_W
    w = SCREEN_W

    parts = []
    parts.append(f'{bdr}\u2502{bg_on}{pad_hud_line(vis1, ansi1, w)}{bdr}\u2502\n')
    parts.append(f'{bdr}\u2502{bg_on}{pad_hud_line(vis2, ansi2, w)}{bdr}\u2502\n')
    parts.append(f'{bdr}\u2570{horiz}\u256f\033[0m')

    return ''.join(parts)


def main():
    # Pre-generate both modes
    models = {
        'single': make_single_banana(),
        'bunch':  make_bunch(),
    }

    mode = 'single'
    ax = ay = az = 0.0
    speed_x = 0.0
    speed_y = 0.08
    speed_z = 0.015
    step = 0.01
    paused = False

    old_settings = termios.tcgetattr(sys.stdin)

    # Clear screen fully on start
    sys.stdout.write('\033[2J\033[?25l')

    try:
        tty.setcbreak(sys.stdin.fileno())

        while True:
            key = read_key()
            if key == 'q':
                speed_x -= step
            elif key == 'w':
                speed_x += step
            elif key == 'a':
                speed_y -= step
            elif key == 's':
                speed_y += step
            elif key == 'z':
                speed_z -= step
            elif key == 'x':
                speed_z += step
            elif key == ' ':
                paused = not paused
            elif key == '\t':
                mode = 'bunch' if mode == 'single' else 'single'
                ax = ay = az = 0.0
                sys.stdout.write('\033[2J')
            elif key == 'r':
                speed_x = 0.0
                speed_y = 0.08
                speed_z = 0.015
                ax = ay = az = 0.0
                paused = False
            elif key == '\x03':  # Ctrl-C
                break

            points, normals, t_values = models[mode]
            frame = render(points, normals, t_values, ax, ay, az, PROJ[mode])
            hud = draw_hud(mode, speed_x, speed_y, speed_z, paused)
            sys.stdout.write('\033[H')
            sys.stdout.write(frame)
            sys.stdout.write(hud)
            sys.stdout.flush()

            if not paused:
                ax += speed_x
                ay += speed_y
                az += speed_z
            time.sleep(0.03)

    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)
        sys.stdout.write('\033[0m\033[?25h\n')


if __name__ == '__main__':
    main()
