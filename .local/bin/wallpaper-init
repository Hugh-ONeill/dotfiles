#!/bin/bash
# Start the awww wallpaper daemon and restore the last wallpaper at login.
#
# awww-daemon caches the last displayed image and restores it on start, but we
# call `awww restore` explicitly (and fall back to the saved pointer) so a
# cold cache still comes up with a wallpaper instead of a black screen.

set -u

# awww owns the background layer; make sure hyprpaper isn't also running.
pkill -x hyprpaper 2>/dev/null

if ! pgrep -x awww-daemon >/dev/null; then
    awww-daemon >/dev/null 2>&1 &
fi

# Wait for the daemon to accept IPC (up to ~10s).
for _ in $(seq 1 50); do
    awww query >/dev/null 2>&1 && break
    sleep 0.2
done

# Restore the cached image; if nothing is displayed, set the saved one.
awww restore >/dev/null 2>&1
if ! awww query 2>/dev/null | grep -q 'displaying: image:'; then
    img="$(readlink -f "$HOME/.cache/current_wallpaper" 2>/dev/null)"
    if [[ ! -f "$img" && -f "$HOME/.cache/wal/wal" ]]; then
        img="$(cat "$HOME/.cache/wal/wal" 2>/dev/null)"
    fi
    if [[ ! -f "$img" ]]; then
        dir="${XDG_PICTURES_DIR:-$HOME/Documents/Pictures}/Backgrounds"
        img="$(find -L "$dir" -maxdepth 1 -type f \
            \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.gif' \) \
            2>/dev/null | head -1)"
    fi
    [[ -f "$img" ]] && awww img "$img" --transition-type none >/dev/null 2>&1
fi
