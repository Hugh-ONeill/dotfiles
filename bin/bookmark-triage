#!/usr/bin/env python3
# Triage Firefox bookmarks. GitHub repos are enriched via the GitHub API
# (through the `gh` CLI) for stars/language/last-push/archived; all other links
# get a concurrent HTTP health check (alive / redirected / dead / blocked).
# The "Other Bookmarks" (unfiled) subtree is skipped by default.
# Emits a markdown report flagging prune/update candidates, duplicates, and a
# per-folder + per-domain breakdown.
# Usage: bookmark-triage [-o OUTPUT.md] [--profile NAME] [--json FILE]
#                        [--stale-years N] [--skip-links] [--include-other]
#                        [--link-workers N] [--link-timeout SECS] [--quiet]

import argparse
import configparser
import json
import os
import re
import shutil
import socket
import sqlite3
import ssl
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request
from collections import defaultdict
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timedelta, timezone

# ============================================================
# CONFIG
# ============================================================

FIREFOX_DIR = os.path.expanduser("~/.mozilla/firefox")
DEFAULT_OUTPUT = os.path.expanduser("~/bookmark-triage.md")
BATCH_SIZE = 80                      # repos per GraphQL request
LINK_WORKERS = 24                    # global concurrent HTTP checks
PER_DOMAIN = 3                       # max concurrent checks against one host
LINK_TIMEOUT = 10                    # seconds per request
UA = ("Mozilla/5.0 (X11; Linux x86_64; rv:128.0) "
      "Gecko/20100101 Firefox/128.0")
NONREPO_OWNERS = {                   # github.com/<this>/... is not a repo
    "orgs", "settings", "sponsors", "marketplace", "topics", "collections",
    "features", "about", "pricing", "explore", "notifications", "search",
    "trending", "apps",
}

GRAPHQL_FIELDS = """
  nameWithOwner
  description
  stargazerCount
  forkCount
  isArchived
  isFork
  isDisabled
  pushedAt
  primaryLanguage { name }
  licenseInfo { spdxId }
"""


def log(msg, quiet=False):
    if not quiet:
        print(msg, file=sys.stderr)


# ============================================================
# FIREFOX PROFILE
# ============================================================

def find_profile(name=None):
    # Locate the places.sqlite for a Firefox profile. With no name, follow the
    # default install's profile from profiles.ini; fall back to Default=1.
    if name:
        path = os.path.join(FIREFOX_DIR, name)
        if not os.path.isdir(path):
            sys.exit(f"profile not found: {path}")
        return os.path.join(path, "places.sqlite")

    ini = os.path.join(FIREFOX_DIR, "profiles.ini")
    if not os.path.exists(ini):
        sys.exit(f"no profiles.ini at {ini}")
    cfg = configparser.ConfigParser()
    cfg.read(ini)

    rel = None
    # ---- prefer the [InstallXXXX] default ----
    for sec in cfg.sections():
        if sec.startswith("Install") and cfg.has_option(sec, "Default"):
            rel = cfg.get(sec, "Default")
            break
    # ---- else a [ProfileN] flagged Default=1 ----
    if rel is None:
        for sec in cfg.sections():
            if cfg.has_option(sec, "Default") and cfg.get(sec, "Default") == "1":
                rel = cfg.get(sec, "Path")
                break
    if rel is None:
        sys.exit("could not determine default Firefox profile")

    path = os.path.join(FIREFOX_DIR, rel, "places.sqlite")
    if not os.path.exists(path):
        sys.exit(f"places.sqlite not found at {path}")
    return path


# ============================================================
# EXTRACT
# ============================================================

def gh_repo(url):
    # github.com/<owner>/<repo>... -> "owner/repo", or None if not a repo URL.
    m = re.match(r"https?://github\.com/([^/]+)/([^/#?]+)", url)
    if not m:
        return None
    owner, name = m.group(1), re.sub(r"\.git$", "", m.group(2))
    if owner.lower() in NONREPO_OWNERS:
        return None
    return f"{owner}/{name}"


def domain_of(url):
    m = re.match(r"https?://([^/]+)", url)
    if not m:
        return "?"
    host = m.group(1).lower().split("@")[-1].split(":")[0]
    return re.sub(r"^(www\.|m\.)", "", host)


def extract(places_path, include_other=False, quiet=False):
    # Copy the (possibly locked) db, then pull every http(s) bookmark with its
    # folder, skipping the "Other Bookmarks" (unfiled) subtree unless asked.
    # Returns rows [(url, title, folder, added)].
    tmp = tempfile.NamedTemporaryFile(suffix=".sqlite", delete=False).name
    shutil.copy(places_path, tmp)
    try:
        con = sqlite3.connect(tmp)
        if include_other:
            where_excl = ""
        else:
            where_excl = """
              AND b.parent NOT IN (
                WITH RECURSIVE unfiled(id) AS (
                  SELECT id FROM moz_bookmarks WHERE guid='unfiled_____'
                  UNION ALL
                  SELECT c.id FROM moz_bookmarks c JOIN unfiled u ON c.parent=u.id
                ) SELECT id FROM unfiled)
            """
        rows = con.execute(f"""
            SELECT p.url, b.title, par.title, b.dateAdded
            FROM moz_bookmarks b
            JOIN moz_places p   ON b.fk = p.id
            JOIN moz_bookmarks par ON b.parent = par.id
            WHERE b.type = 1 AND p.url GLOB 'http*://*'{where_excl}
        """).fetchall()
        con.close()
    finally:
        os.unlink(tmp)
    log(f"extracted {len(rows)} bookmarks"
        f"{'' if include_other else ' (Other Bookmarks excluded)'}", quiet)
    return rows


# ============================================================
# ENRICH: GITHUB
# ============================================================

def chunks(seq, n):
    for i in range(0, len(seq), n):
        yield seq[i:i + n]


def enrich_github(repos, quiet=False):
    # Batch repos through the GitHub GraphQL API via `gh`. Repos that fail to
    # resolve (deleted/renamed/private) are marked {"status": "dead"}.
    meta = {}
    done = 0
    for batch in chunks(repos, BATCH_SIZE):
        aliases, parts = {}, []
        for i, repo in enumerate(batch):
            owner, name = repo.split("/", 1)
            a = f"r{i}"
            aliases[a] = repo
            owner_e, name_e = owner.replace('"', '\\"'), name.replace('"', '\\"')
            parts.append(f'{a}: repository(owner: "{owner_e}", name: "{name_e}") '
                         f'{{{GRAPHQL_FIELDS}}}')
        query = "query {\n" + "\n".join(parts) + "\n}"
        res = subprocess.run(["gh", "api", "graphql", "-f", f"query={query}"],
                             capture_output=True, text=True)
        # gh exits non-zero if ANY node 404s, but still returns partial `data`.
        data = {}
        if res.stdout.strip():
            try:
                data = json.loads(res.stdout).get("data", {}) or {}
            except json.JSONDecodeError:
                log(f"  unparseable batch: {res.stderr[:160]}", quiet)
        for a, repo in aliases.items():
            node = data.get(a)
            if node is None:
                meta[repo] = {"status": "dead"}
            else:
                meta[repo] = {
                    "status": "ok",
                    "stars": node["stargazerCount"],
                    "forks": node["forkCount"],
                    "archived": node["isArchived"],
                    "disabled": node["isDisabled"],
                    "isFork": node["isFork"],
                    "pushedAt": node.get("pushedAt"),
                    "lang": (node.get("primaryLanguage") or {}).get("name"),
                    "license": (node.get("licenseInfo") or {}).get("spdxId"),
                    "description": node.get("description"),
                }
        done += len(batch)
        log(f"  github {done}/{len(repos)}", quiet)
    return meta


# ============================================================
# ENRICH: HTTP LINK HEALTH
# ============================================================

def classify_http(url, code, final):
    # Map an HTTP status + final URL to a health bucket.
    redirected = bool(final) and final.rstrip("/") != url.rstrip("/")
    if 200 <= code < 300:
        bucket = "alive"
    elif code in (404, 410):
        bucket = "dead"
    elif code in (401, 403, 429):
        bucket = "blocked"          # bot-blocked / auth — NOT confidently dead
    elif 400 <= code < 500:
        bucket = "client_error"
    elif 500 <= code < 600:
        bucket = "server_error"
    else:
        bucket = "other"
    return {"bucket": bucket, "code": code,
            "final": final if redirected else None}


def _transient(code):
    # Errors that warrant a retry: a reset/timeout usually means we hit the host
    # too hard, not that the page is gone.
    s = str(code).lower()
    return ("timeout" in s or "reset" in s or "network is unreachable" in s
            or "no-response" in s)


def _attempt(url, timeout):
    # One request cycle: HEAD first (cheap), fall back to GET when refused.
    ctx = ssl.create_default_context()
    headers = {"User-Agent": UA, "Accept": "*/*"}
    for method in ("HEAD", "GET"):
        req = urllib.request.Request(url, method=method, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
                return classify_http(url, r.getcode(), r.geturl())
        except urllib.error.HTTPError as e:
            if method == "HEAD" and e.code in (403, 405, 501):
                continue                                # method refused: try GET
            return classify_http(url, e.code, getattr(e, "url", url))
        except urllib.error.URLError as e:
            reason = e.reason
            if isinstance(reason, socket.gaierror):
                return {"bucket": "dead", "code": "DNS", "final": None}
            if isinstance(reason, (ssl.SSLCertVerificationError, ssl.SSLError)):
                return {"bucket": "tls_error", "code": "TLS", "final": None}
            if isinstance(reason, (socket.timeout, TimeoutError)):
                return {"bucket": "unreachable", "code": "timeout", "final": None}
            return {"bucket": "unreachable", "code": str(reason)[:40], "final": None}
        except (socket.timeout, TimeoutError):
            return {"bucket": "unreachable", "code": "timeout", "final": None}
        except Exception as e:                          # noqa: BLE001 — be robust
            return {"bucket": "unreachable", "code": type(e).__name__, "final": None}
    return {"bucket": "unreachable", "code": "no-response", "final": None}


def check_one(url, timeout, sem):
    # Throttle per host (sem), and retry transient failures once after a pause —
    # connection resets are usually self-inflicted from hammering a busy domain.
    with sem:
        res = _attempt(url, timeout)
    if res["bucket"] == "unreachable" and _transient(res["code"]):
        time.sleep(1.5)
        with sem:
            res = _attempt(url, timeout)
    return res


def _pass(urls, workers, timeout, per_domain, label, quiet):
    health = {}
    done, total = 0, len(urls)
    step = max(1, total // 20)
    sems = defaultdict(lambda: threading.Semaphore(per_domain))
    with ThreadPoolExecutor(max_workers=workers) as ex:
        futs = {ex.submit(check_one, u, timeout, sems[domain_of(u)]): u
                for u in urls}
        for fut in as_completed(futs):
            url = futs[fut]
            try:
                health[url] = fut.result()
            except Exception as e:                      # noqa: BLE001
                health[url] = {"bucket": "unreachable",
                               "code": type(e).__name__, "final": None}
            done += 1
            if done % step == 0 or done == total:
                log(f"  {label} {done}/{total}", quiet)
    return health


def check_links(urls, workers, timeout, quiet=False):
    # Main pass at full concurrency, then a gentle low-concurrency recheck of
    # transient failures (resets/timeouts) — these are usually rate-limiting on
    # busy hosts (e.g. wiki.archlinux.org), not genuinely dead links.
    health = _pass(urls, workers, timeout, PER_DOMAIN, "links", quiet)
    retry = [u for u, v in health.items()
             if v["bucket"] == "unreachable" and _transient(v["code"])]
    if retry:
        log(f"  rechecking {len(retry)} transient failures gently...", quiet)
        health.update(_pass(retry, max(4, workers // 4), timeout + 4, 1,
                            "recheck", quiet))
    return health


# ============================================================
# REPORT
# ============================================================

def render(rows, gh_meta, health, stale_years):
    today = datetime.now(timezone.utc)
    stale_before = (today - timedelta(days=365 * stale_years)).strftime("%Y-%m-%d")
    today_s = today.strftime("%Y-%m-%d")

    # ---- index the rows ----
    repo_bm = defaultdict(list)       # owner/repo -> [instance]
    other_bm = defaultdict(list)      # url -> [instance]
    url_count = defaultdict(int)
    repo_urls = defaultdict(set)
    for url, title, folder, added in rows:
        inst = {"folder": folder or "(root)", "title": title, "added": added}
        url_count[url] += 1
        repo = gh_repo(url)
        if repo:
            repo_bm[repo].append(inst)
            repo_urls[repo].add(url)
        else:
            other_bm[url].append(inst)

    o = []
    w = o.append

    # ======================= header =======================
    n_repos = len(repo_bm)
    n_other = len(other_bm)
    w("# Bookmark Triage")
    w("")
    w(f"_{len(rows)} bookmarks · {n_repos} GitHub repos · {n_other} other links "
      f"· generated {today_s}_")
    w("")

    # ======================= GITHUB =======================
    if gh_meta:
        ok = [r for r in repo_bm if gh_meta.get(r, {}).get("status") == "ok"]
        dead = [r for r in repo_bm if gh_meta.get(r, {}).get("status") == "dead"]
        archived = [r for r in ok if gh_meta[r]["archived"]]
        stale = [r for r in ok if not gh_meta[r]["archived"]
                 and (gh_meta[r]["pushedAt"] or "")[:10] < stale_before]

        def stars(r):
            return gh_meta.get(r, {}).get("stars", 0)

        def gline(r, flag=""):
            m = gh_meta[r]
            desc = (m.get("description") or "").strip().replace("\n", " ")
            if len(desc) > 90:
                desc = desc[:87] + "..."
            lang = m.get("lang") or "—"
            tail = f" — {desc}" if desc else ""
            return (f"- **[{r}](https://github.com/{r})** ★{m['stars']:,} · "
                    f"{lang} · pushed {(m.get('pushedAt') or '')[:10]}{tail}{flag}")

        w("## GitHub repos")
        w("")
        w("| Metric | Count |")
        w("|---|---|")
        w(f"| Unique repos | {n_repos} |")
        w(f"| **Dead / renamed / private** | **{len(dead)}** |")
        w(f"| Archived upstream | {len(archived)} |")
        w(f"| Stale (no push since {stale_before}) | {len(stale)} |")
        w(f"| Combined stars | {sum(stars(r) for r in ok):,} |")
        w("")
        w(f"### ⚑ Dead / renamed / deleted repos ({len(dead)})")
        w("")
        for r in sorted(dead):
            folders = ", ".join(sorted({i["folder"] for i in repo_bm[r]}))
            w(f"- `{r}` — in _{folders}_")
        w("")
        w(f"### Archived upstream ({len(archived)})")
        w("")
        for r in sorted(archived, key=stars, reverse=True):
            w(gline(r))
        w("")
        w("### ★ Most-starred (top 30)")
        w("")
        for r in sorted(ok, key=stars, reverse=True)[:30]:
            w(gline(r))
        w("")

    # ======================= NON-GITHUB =======================
    if health:
        by_bucket = defaultdict(list)
        for url in other_bm:
            by_bucket[health.get(url, {}).get("bucket", "unchecked")].append(url)

        def oline(url, note=""):
            titles = [i["title"] for i in other_bm[url] if i["title"]]
            title = (titles[0][:70] + "…") if titles and len(titles[0]) > 70 \
                else (titles[0] if titles else "")
            folders = ", ".join(sorted({i["folder"] for i in other_bm[url]}))
            label = f"{title} — " if title else ""
            return f"- {label}<{url}> _({folders})_{note}"

        w("## Non-GitHub links")
        w("")
        w("| Health | Count |")
        w("|---|---|")
        w(f"| Alive | {len(by_bucket['alive'])} |")
        w(f"| Redirected (new URL) | "
          f"{sum(1 for u in other_bm if health.get(u, {}).get('final'))} |")
        w(f"| **Dead (404/410/DNS)** | **{len(by_bucket['dead'])}** |")
        w(f"| Blocked / unverifiable (403/429) | {len(by_bucket['blocked'])} |")
        w(f"| Server error (5xx) | {len(by_bucket['server_error'])} |")
        w(f"| Client error (other 4xx) | {len(by_bucket['client_error'])} |")
        w(f"| TLS / cert error | {len(by_bucket['tls_error'])} |")
        w(f"| Unreachable (timeout/conn) | {len(by_bucket['unreachable'])} |")
        w("")

        dead_links = by_bucket["dead"]
        w(f"### ⚑ Dead links — prune candidates ({len(dead_links)})")
        w("404 / 410 / DNS failure. Confidently gone.")
        w("")
        for url in sorted(dead_links, key=domain_of):
            code = health[url]["code"]
            w(oline(url, f" `{code}`"))
        w("")

        redirected = [u for u in other_bm if health.get(u, {}).get("final")]
        w(f"### ⤳ Redirected — update candidates ({len(redirected)})")
        w("Bookmark resolves but lands elsewhere now. Consider updating the URL.")
        w("")
        for url in sorted(redirected, key=domain_of):
            w(oline(url, f"\n    → now: <{health[url]['final']}>"))
        w("")

        for label, key in [("Server errors (5xx)", "server_error"),
                           ("Other client errors (4xx)", "client_error"),
                           ("TLS / certificate errors", "tls_error"),
                           ("Unreachable (timeout/connection)", "unreachable")]:
            urls = by_bucket[key]
            if not urls:
                continue
            w(f"### {label} ({len(urls)})")
            w("May be temporary — recheck before pruning.")
            w("")
            for url in sorted(urls, key=domain_of):
                w(oline(url, f" `{health[url]['code']}`"))
            w("")

        if by_bucket["blocked"]:
            w(f"### Blocked / unverifiable ({len(by_bucket['blocked'])})")
            w("Returned 403/429 to an automated request — almost certainly fine "
              "in a browser; not prunable on this signal.")
            w("")
            dom_blocked = defaultdict(int)
            for url in by_bucket["blocked"]:
                dom_blocked[domain_of(url)] += 1
            for dom, c in sorted(dom_blocked.items(), key=lambda kv: -kv[1]):
                w(f"- `{dom}` — {c}")
            w("")

        # ---- top domains ----
        dom_count = defaultdict(int)
        for url in other_bm:
            dom_count[domain_of(url)] += 1
        w("### Top domains")
        w("")
        for dom, c in sorted(dom_count.items(), key=lambda kv: -kv[1])[:25]:
            w(f"- `{dom}` — {c}")
        w("")

    # ======================= SHARED: DUPLICATES =======================
    true_dupes = {u: c for u, c in url_count.items() if c > 1}
    multipage = {r: us for r, us in repo_urls.items() if len(us) > 1}
    w(f"## ⧉ Duplicate URLs ({len(true_dupes)})")
    w("Identical URL bookmarked more than once.")
    w("")
    for u, c in sorted(true_dupes.items(), key=lambda kv: -kv[1]):
        w(f"- `{u}` ×{c}")
    w("")
    if multipage:
        w(f"## ⌥ GitHub repos saved as many sub-pages ({len(multipage)})")
        w("")
        for r in sorted(multipage, key=lambda r: -len(multipage[r]))[:25]:
            w(f"- `{r}` — {len(multipage[r])} distinct pages")
        w("")

    # ======================= PER-FOLDER =======================
    w("## By folder")
    w("")
    folder_items = defaultdict(lambda: {"repos": set(), "links": set()})
    for url, title, folder, added in rows:
        f = folder or "(root)"
        if gh_repo(url):
            folder_items[f]["repos"].add(gh_repo(url))
        else:
            folder_items[f]["links"].add(url)
    for folder in sorted(folder_items,
                         key=lambda f: -(len(folder_items[f]["repos"])
                                         + len(folder_items[f]["links"]))):
        repos = folder_items[folder]["repos"]
        links = folder_items[folder]["links"]
        ndead_l = sum(1 for u in links if health.get(u, {}).get("bucket") == "dead")
        ndead_r = sum(1 for r in repos
                      if gh_meta.get(r, {}).get("status") == "dead")
        flags = []
        if ndead_l or ndead_r:
            flags.append(f"{ndead_l + ndead_r} dead")
        flag_s = f" · {', '.join(flags)}" if flags else ""
        w(f"### {folder} ({len(repos)} repos · {len(links)} links{flag_s})")
        w("")
        if gh_meta and repos:
            for r in sorted(repos,
                            key=lambda r: gh_meta.get(r, {}).get("stars", 0),
                            reverse=True)[:5]:
                if gh_meta.get(r, {}).get("status") == "ok":
                    m = gh_meta[r]
                    w(f"- **[{r}](https://github.com/{r})** ★{m['stars']:,}")
        w("")

    return "\n".join(o)


# ============================================================
# MAIN
# ============================================================

def main():
    ap = argparse.ArgumentParser(description="Triage Firefox bookmarks.")
    ap.add_argument("-o", "--output", default=DEFAULT_OUTPUT,
                    help=f"markdown output path (default: {DEFAULT_OUTPUT})")
    ap.add_argument("--profile", help="Firefox profile dir name (default: auto-detect)")
    ap.add_argument("--json", help="also dump enriched data to this JSON file")
    ap.add_argument("--stale-years", type=int, default=2,
                    help="flag repos with no push in N years (default: 2)")
    ap.add_argument("--skip-links", action="store_true",
                    help="only triage GitHub repos; skip the HTTP health check")
    ap.add_argument("--include-other", action="store_true",
                    help="include the 'Other Bookmarks' subtree (skipped by default)")
    ap.add_argument("--link-workers", type=int, default=LINK_WORKERS,
                    help=f"concurrent HTTP checks (default: {LINK_WORKERS})")
    ap.add_argument("--link-timeout", type=int, default=LINK_TIMEOUT,
                    help=f"per-request timeout seconds (default: {LINK_TIMEOUT})")
    ap.add_argument("--quiet", action="store_true", help="suppress progress output")
    args = ap.parse_args()

    if not shutil.which("gh"):
        sys.exit("`gh` CLI not found - install it and run `gh auth login`")

    places = find_profile(args.profile)
    rows = extract(places, args.include_other, args.quiet)
    if not rows:
        sys.exit("no bookmarks found")

    repos = sorted({gh_repo(u) for u, *_ in rows if gh_repo(u)})
    other = sorted({u for u, *_ in rows if not gh_repo(u)})
    log(f"-> {len(repos)} github repos, {len(other)} other links", args.quiet)

    gh_meta = enrich_github(repos, args.quiet) if repos else {}
    health = {}
    if not args.skip_links and other:
        health = check_links(other, args.link_workers, args.link_timeout, args.quiet)

    report = render(rows, gh_meta, health, args.stale_years)
    with open(args.output, "w") as f:
        f.write(report)
    log(f"wrote {args.output}", args.quiet)

    if args.json:
        with open(args.json, "w") as f:
            json.dump({"github": gh_meta, "links": health}, f)
        log(f"wrote {args.json}", args.quiet)


if __name__ == "__main__":
    main()
